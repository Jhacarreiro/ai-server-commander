# The application does not load this file automatically.
# Export these values in your shell or process manager.
SAFE_MODE=true
COMMAND_TIMEOUT_MS=120000
MAX_OUTPUT_CHARS=12000
MAX_SCRIPT_BODY_BYTES=524288
SHELL=/bin/bash
NODE_ENV=production
OAUTH_STATE_PATH=./runtime/oauth-state.json
OAUTH_AUTH_CODE_TTL_SECONDS=300
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
